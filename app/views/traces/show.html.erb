<div class="mx-auto w-full max-w-4xl space-y-8">
  <header>
    <%= link_to "← Back to ticket", ticket_path(@ticket), class: "text-sm font-semibold text-slate-600 transition hover:text-slate-900" %>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Dedicated Trace</p>
    <h1 class="text-3xl font-bold text-slate-900">Ticket #<%= @ticket.id %> trace</h1>
    <div class="mt-3 flex flex-wrap gap-2">
      <span class="<%= ticket_status_badge_class(@ticket) %> rounded-full px-3 py-1 text-xs font-medium">
        <%= ticket_status_label(@ticket) %>
      </span>
      <% if @ticket.manual_takeover? %>
        <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-900">Human-owned ticket</span>
      <% end %>
    </div>
  </header>

  <% if @ticket.manual_takeover? %>
    <section class="rounded-3xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
      <p class="text-sm font-semibold text-amber-950">Manual takeover is active.</p>
      <p class="mt-2 text-sm text-amber-900">Automation has already stopped for this ticket. New customer replies now stay with support.</p>
    </section>
  <% elsif @ticket.human_handoff_available? && @ticket.summary.present? %>
    <section class="rounded-3xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
      <p class="text-sm font-semibold text-amber-950">Human specialist summary</p>
      <p class="mt-2 text-sm text-amber-900"><%= @ticket.summary %></p>
      <p class="mt-2 text-sm text-amber-900">Automation recommended human review, but the customer has not accepted handoff yet.</p>
    </section>
  <% end %>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between gap-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Trace Timeline</p>
        <h2 class="mt-2 text-lg font-semibold text-slate-900">Customer message, automation steps, and tool actions</h2>
      </div>
      <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700"><%= @ticket.agent_runs.count %> runs</span>
    </div>

    <div class="mt-6 space-y-4">
      <div class="rounded-2xl border border-slate-200 px-4 py-4">
        <div class="flex items-center justify-between gap-4">
          <p class="font-semibold text-slate-900">Customer message</p>
          <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700"><%= @ticket.customer.email %></span>
        </div>
        <p class="mt-2 text-sm text-slate-700"><%= @ticket.messages.order(:created_at).find_by(role: "user")&.content.presence || "No customer message recorded." %></p>
      </div>

      <% if @ticket.agent_runs.any? %>
        <% @ticket.agent_runs.order(:created_at).each do |run| %>
          <% snapshot = JSON.parse(run.output_snapshot || "{}") rescue {} %>
          <% run_tools = @ticket.tool_calls.select { |call| call.agent_run_id == run.id } %>
          <div class="rounded-2xl border border-slate-200 px-4 py-4">
            <div class="flex items-center justify-between gap-4">
              <div>
                <p class="font-semibold text-slate-900"><%= trace_step_label(run) %></p>
                <p class="mt-1 text-sm text-slate-600"><%= run.reasoning_summary.presence || "No summary recorded." %></p>
              </div>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700"><%= agent_source_label(snapshot) %></span>
            </div>

            <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-600">
              <span class="rounded-full bg-slate-50 px-3 py-1">status: <%= run.status %></span>
              <span class="rounded-full bg-slate-50 px-3 py-1">decision: <%= run.decision.presence || "n/a" %></span>
              <span class="rounded-full bg-slate-50 px-3 py-1">confidence: <%= format_confidence(run.confidence) %></span>
            </div>

            <% if run_tools.any? %>
              <div class="mt-4 space-y-3 border-t border-slate-200 pt-4">
                <% run_tools.each do |call| %>
                  <div class="rounded-2xl bg-slate-50 px-4 py-3">
                    <div class="flex items-center justify-between gap-4">
                      <p class="font-semibold text-slate-900"><%= call.tool_name %></p>
                      <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700"><%= tool_kind_label(call.tool_name) %></span>
                    </div>
                    <details class="mt-3">
                      <summary class="cursor-pointer text-sm font-medium text-slate-700">View tool payloads</summary>
                      <div class="mt-3 grid gap-3 md:grid-cols-2">
                        <div class="rounded-2xl bg-slate-950 p-4 text-xs text-slate-100">
                          <p class="font-semibold uppercase tracking-[0.2em] text-slate-400">Input payload</p>
                          <pre class="mt-3 overflow-x-auto whitespace-pre-wrap"><%= pretty_json(call.input_payload) %></pre>
                        </div>
                        <div class="rounded-2xl bg-slate-950 p-4 text-xs text-slate-100">
                          <p class="font-semibold uppercase tracking-[0.2em] text-slate-400">Output payload</p>
                          <pre class="mt-3 overflow-x-auto whitespace-pre-wrap"><%= pretty_json(call.output_payload) %></pre>
                        </div>
                      </div>
                    </details>
                  </div>
                <% end %>
              </div>
            <% end %>

            <details class="mt-4">
              <summary class="cursor-pointer text-sm font-medium text-slate-700">View run payload</summary>
              <div class="mt-3 grid gap-3 md:grid-cols-2">
                <div class="rounded-2xl bg-slate-950 p-4 text-xs text-slate-100">
                  <p class="font-semibold uppercase tracking-[0.2em] text-slate-400">Input snapshot</p>
                  <pre class="mt-3 overflow-x-auto whitespace-pre-wrap"><%= run.input_snapshot.presence || "No input snapshot recorded." %></pre>
                </div>
                <div class="rounded-2xl bg-slate-950 p-4 text-xs text-slate-100">
                  <p class="font-semibold uppercase tracking-[0.2em] text-slate-400">Output payload</p>
                  <pre class="mt-3 overflow-x-auto whitespace-pre-wrap"><%= pretty_json(run.output_snapshot) %></pre>
                </div>
              </div>
            </details>
          </div>
        <% end %>
      <% else %>
        <p class="text-sm text-slate-600">No agent runs yet. The first implementation slice only creates ticket-backed conversations.</p>
      <% end %>
    </div>
  </section>
</div>
