<div class="mx-auto w-full max-w-4xl space-y-8">
  <header>
    <%= link_to "← Back to ticket", ticket_path(@ticket), class: "text-sm font-semibold text-slate-600 transition hover:text-slate-900" %>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Dedicated Trace</p>
    <h1 class="text-3xl font-bold text-slate-900">Ticket #<%= @ticket.id %> trace</h1>
  </header>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Agent Runs</h2>
    <% if @ticket.agent_runs.any? %>
      <div class="mt-4 space-y-3">
        <% @ticket.agent_runs.order(:created_at).each do |run| %>
          <% snapshot = JSON.parse(run.output_snapshot || "{}") rescue {} %>
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <div class="flex items-center justify-between gap-4">
              <p class="font-semibold text-slate-900"><%= run.agent_name %></p>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                source: <%= snapshot["source"] || "unknown" %>
              </span>
            </div>
            <p class="mt-1 text-sm text-slate-600"><%= run.reasoning_summary.presence || "No summary recorded." %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-slate-600">No agent runs yet. The first implementation slice only creates ticket-backed conversations.</p>
    <% end %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Tool Calls</h2>
    <% if @ticket.tool_calls.any? %>
      <div class="mt-4 space-y-3">
        <% @ticket.tool_calls.order(:created_at).each do |call| %>
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <p class="font-semibold text-slate-900"><%= call.tool_name %></p>
            <p class="mt-1 text-sm text-slate-600"><%= call.status %></p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-slate-600">No tool calls yet.</p>
    <% end %>
  </section>
</div>
