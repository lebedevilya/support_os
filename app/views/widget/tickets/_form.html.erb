<%= form_with model: [ :widget, ticket ], class: "mt-8 space-y-5" do |form| %>
  <% customer = local_assigns[:customer] %>

  <% if customer&.errors&.any? %>
    <div class="rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-800">
      <p class="font-semibold">Please enter a valid email before starting the chat.</p>
      <ul class="mt-2 space-y-1">
        <% customer.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <% if local_assigns[:company].present? %>
    <%= form.hidden_field :company_id, value: company.id, name: "ticket[company_id]" %>
  <% else %>
    <div>
      <%= form.label :company_id, "Company", class: "mb-2 block text-sm font-medium text-slate-800" %>
      <%= form.select :company_id, options_from_collection_for_select(companies, :id, :name), {}, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3" %>
    </div>
  <% end %>

  <div>
    <%= form.label :email, "Email", class: "mb-2 block text-sm font-medium text-slate-800" %>
    <%= form.email_field :email, name: "ticket[email]", value: customer&.email, required: true, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3" %>
  </div>

  <div>
    <%= form.label :content, "Message", class: "mb-2 block text-sm font-medium text-slate-800" %>
    <%= form.text_area :content, name: "ticket[content]", rows: 3, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3", data: { controller: "enter-submit", action: "keydown->enter-submit#submitOnEnter" } %>
  </div>

  <%= form.submit "Send", class: "rounded-full bg-slate-900 px-5 py-3 text-sm font-semibold text-white" %>
<% end %>
