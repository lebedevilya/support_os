<% prompts = widget_scenarios_for(company) %>
<% if prompts.any? %>
  <section class="mt-4 space-y-3">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Example scenarios (demo only)</p>
      <p class="mt-1 text-sm text-slate-600">Click one to play out a seeded support path.</p>
    </div>
    <div class="flex flex-wrap gap-2">
      <% prompts.each do |scenario| %>
        <button
          type="button"
          class="cursor-pointer rounded-full border border-slate-300 bg-white px-3 py-2 text-left text-xs font-medium text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-slate-900 hover:bg-slate-900 hover:text-white focus:outline-none focus:ring-2 focus:ring-slate-400"
          data-action="scenario-play#play"
          data-scenario-prompt="<%= scenario[:prompt] %>"
          data-scenario-email="<%= scenario[:email] %>"
        ><%= scenario[:prompt] %></button>
      <% end %>
    </div>
  </section>
<% end %>
