<%= turbo_stream_from ticket %>

<div id="<%= dom_id(ticket, :chat) %>" class="space-y-6">
  <div class="space-y-3">
    <% ticket.messages.order(:created_at).each do |message| %>
      <%= render "widget/tickets/message", message: message %>
    <% end %>

    <% if ticket.processing? %>
      <div data-role="assistant-loading" class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3">
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">assistant</p>
        <p class="mt-2 text-sm leading-6 text-slate-800">Loading...</p>
      </div>
    <% end %>
  </div>

  <% if ticket.status == "resolved" %>
    <div class="rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-900">
      This conversation is closed.
    </div>
  <% elsif ticket.processing? %>
    <div class="rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-700">
      Your message was submitted. The assistant reply will appear here automatically.
    </div>
  <% else %>
    <div class="flex flex-wrap gap-3">
      <%= form_with url: close_widget_ticket_path(ticket), method: :patch, class: "inline" do %>
        <%= submit_tag "This solved my issue", class: "rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
      <% end %>
    </div>

    <%= form_with url: widget_ticket_messages_path(ticket), scope: :message, class: "space-y-3" do |form| %>
      <%= form.text_area :content, rows: 4, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3", data: { controller: "enter-submit", action: "keydown->enter-submit#submitOnEnter" } %>
      <%= form.submit "Send follow-up", class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-900" %>
    <% end %>
  <% end %>
</div>
