<%= turbo_frame_tag "support_widget" do %>
  <div class="mx-auto w-full max-w-2xl rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
    <div class="space-y-2">
      <h1 class="text-3xl font-bold tracking-tight text-slate-900">Start support conversation</h1>
      <p class="text-sm text-slate-600">This demo turns each message into a support ticket behind the scenes.</p>
    </div>

    <%= render "form", ticket: @ticket, companies: @companies, customer: @customer %>
  </div>
<% end %>
