<div class="fixed bottom-5 right-5 z-50 w-[calc(100vw-2.5rem)] max-w-md" data-controller="widget-shell">
  <button
    type="button"
    class="ml-auto flex min-h-16 w-full cursor-pointer items-center justify-center gap-3 rounded-[1.75rem] bg-slate-950 px-6 py-4 text-base font-semibold text-white shadow-2xl shadow-slate-900/30 transition hover:-translate-y-1 hover:bg-slate-900 sm:min-h-0 sm:w-auto"
    data-widget-shell-target="openButton"
    data-action="widget-shell#open"
    aria-controls="support_widget"
    aria-label="Open support chat"
  >
    <span class="inline-flex h-3.5 w-3.5 rounded-full bg-emerald-400 ring-4 ring-emerald-400/20"></span>
    <span>Chat with support</span>
  </button>

  <div
    class="mt-4 hidden h-[min(84vh,48rem)] max-h-[calc(100vh-5rem)] flex flex-col overflow-hidden rounded-[2rem] border border-slate-200 bg-white shadow-2xl"
    data-widget-shell-target="panel"
  >
    <div class="flex items-center justify-between border-b border-slate-200 bg-slate-50 px-5 py-4">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500"><%= company.name %> support</p>
        <p class="mt-1 text-sm text-slate-600">Replies stay on this page.</p>
      </div>
      <button
        type="button"
        class="flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-slate-300 text-slate-700 transition hover:bg-slate-100 hover:text-slate-950"
        data-action="widget-shell#close"
        aria-label="Close support chat"
      >
        <span aria-hidden="true" class="text-xl leading-none">&times;</span>
      </button>
    </div>

    <%= turbo_frame_tag "support_widget", class: "flex min-h-0 flex-1 flex-col" do %>
      <div class="flex min-h-0 flex-1 flex-col overflow-y-auto p-5">
        <div class="space-y-2">
          <h2 class="text-2xl font-bold tracking-tight text-slate-900">Start support conversation</h2>
          <p class="text-sm text-slate-600">Ask a question without leaving <%= company.name %>.</p>
        </div>

        <%= render "widget/tickets/form", ticket: ticket, company: company %>
      </div>
    <% end %>
  </div>
</div>
