<% content_for :full_bleed, true %>
<% content_for :title, @company.name %>

<div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(15,23,42,0.08),_transparent_35%),linear-gradient(180deg,_#fff,_#f8fafc_55%,_#eef2ff)]">
  <header class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-6 lg:px-10">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.35em] text-slate-500"><%= @landing[:eyebrow] %></p>
      <h1 class="mt-2 text-xl font-semibold text-slate-950"><%= @company.name %></h1>
    </div>
    <nav class="hidden gap-6 text-sm text-slate-600 md:flex">
      <a href="#features">Features</a>
      <a href="#support">Support</a>
      <a href="/">Back to demo index</a>
    </nav>
  </header>

  <main class="mx-auto grid w-full max-w-6xl gap-16 px-6 pb-28 pt-8 lg:grid-cols-[1.15fr_0.85fr] lg:px-10">
    <section class="space-y-8">
      <div class="space-y-6">
        <p class="inline-flex rounded-full border border-slate-300/80 bg-white/80 px-4 py-2 text-xs font-semibold uppercase tracking-[0.3em] text-slate-600">
          Demo company landing page
        </p>
        <h2 class="max-w-3xl text-5xl font-black tracking-tight text-slate-950 sm:text-6xl">
          <%= @landing[:hero_title] %>
        </h2>
        <p class="max-w-2xl text-lg leading-8 text-slate-600">
          <%= @landing[:hero_copy] %>
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="#support" class="rounded-full bg-slate-950 px-6 py-3 text-sm font-semibold text-white"><%= @landing[:primary_cta] %></a>
        <a href="#features" class="rounded-full border border-slate-300 bg-white px-6 py-3 text-sm font-semibold text-slate-900"><%= @landing[:secondary_cta] %></a>
      </div>

      <div class="grid gap-4 sm:grid-cols-3">
        <% @landing[:stats].each do |value, label| %>
          <article class="rounded-3xl border border-slate-200 bg-white/90 p-5 shadow-sm">
            <p class="text-2xl font-black text-slate-950"><%= value %></p>
            <p class="mt-2 text-sm text-slate-600"><%= label %></p>
          </article>
        <% end %>
      </div>
    </section>

    <aside class="space-y-5">
      <section id="features" class="rounded-[2rem] border border-slate-200 bg-white p-8 shadow-sm">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">Why people use it</p>
        <ul class="mt-6 space-y-4 text-sm leading-7 text-slate-700">
          <% @landing[:features].each do |feature| %>
            <li class="rounded-2xl bg-slate-50 px-4 py-3"><%= feature %></li>
          <% end %>
        </ul>
      </section>

      <section class="rounded-[2rem] border border-slate-900 bg-slate-950 p-8 text-white shadow-xl">
        <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-400">Support-ready product</p>
        <h3 class="mt-3 text-2xl font-bold"><%= @landing[:spotlight_title] %></h3>
        <p class="mt-4 text-sm leading-7 text-slate-300"><%= @landing[:spotlight_copy] %></p>
      </section>
    </aside>
  </main>

  <section id="support" class="mx-auto w-full max-w-6xl px-6 pb-24 lg:px-10">
    <div class="rounded-[2rem] border border-slate-200 bg-white/80 p-8 shadow-sm backdrop-blur">
      <p class="text-xs font-semibold uppercase tracking-[0.3em] text-slate-500">Support embedded on the site</p>
      <h3 class="mt-3 text-3xl font-bold text-slate-950">The widget behaves like a real support entry point.</h3>
      <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600">
        Open the chat in the bottom-right corner, ask a product question, and watch the ticket-backed flow continue without leaving the company page.
      </p>
    </div>
  </section>

  <%= render "widget/tickets/embedded_shell", company: @company, ticket: @ticket %>
</div>
