<div class="mx-auto w-full max-w-5xl space-y-8">
  <header class="flex items-end justify-between gap-6">
    <div>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Ticket Detail</p>
      <h1 class="text-3xl font-bold text-slate-900">Ticket #<%= @ticket.id %></h1>
    </div>
    <%= link_to "View trace", ticket_trace_path(@ticket), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-900" %>
  </header>

  <section class="grid gap-6 md:grid-cols-2">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Metadata</h2>
      <dl class="mt-4 space-y-2 text-sm text-slate-700">
        <div><dt class="font-medium">Company</dt><dd><%= @ticket.company.name %></dd></div>
        <div><dt class="font-medium">Customer</dt><dd><%= @ticket.customer.email %></dd></div>
        <div><dt class="font-medium">Status</dt><dd><%= @ticket.status %></dd></div>
        <div><dt class="font-medium">Current layer</dt><dd><%= @ticket.current_layer %></dd></div>
      </dl>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Trace Summary</h2>
      <% if @ticket.agent_runs.any? %>
        <div class="mt-4 space-y-3">
          <% @ticket.agent_runs.order(:created_at).each do |run| %>
            <% snapshot = JSON.parse(run.output_snapshot || "{}") rescue {} %>
            <div class="rounded-2xl border border-slate-200 px-4 py-3">
              <div class="flex items-center justify-between gap-4">
                <p class="font-semibold text-slate-900"><%= run.agent_name %></p>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                  source: <%= snapshot["source"] || "unknown" %>
                </span>
              </div>
              <p class="mt-2 text-sm text-slate-600"><%= run.reasoning_summary %></p>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-4 text-sm text-slate-600">Agent runs and tool calls will appear here once the AI pipeline is wired in.</p>
      <% end %>
    </div>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Conversation</h2>
    <div class="mt-4 space-y-3">
      <% @ticket.messages.order(:created_at).each do |message| %>
        <%= render "widget/tickets/message", message: message %>
      <% end %>
    </div>
  </section>
</div>
