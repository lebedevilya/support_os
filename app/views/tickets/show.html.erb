<div class="mx-auto w-full max-w-5xl space-y-8">
  <header class="flex items-end justify-between gap-6">
    <div>
      <%= link_to "← Back to tickets", tickets_path, class: "text-sm font-semibold text-slate-600 transition hover:text-slate-900" %>
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Ticket Detail</p>
      <h1 class="text-3xl font-bold text-slate-900">Ticket #<%= @ticket.id %></h1>
      <div class="mt-3 flex flex-wrap gap-2">
        <span class="<%= ticket_status_badge_class(@ticket) %> rounded-full px-3 py-1 text-xs font-medium">
          <%= ticket_status_label(@ticket) %>
        </span>
        <% if @ticket.manual_takeover? %>
          <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-900">Human-owned ticket</span>
        <% end %>
      </div>
    </div>
    <%= link_to "View trace", ticket_trace_path(@ticket), class: "rounded-full border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-900" %>
  </header>

  <% if @ticket.manual_takeover? %>
    <section class="rounded-3xl border border-amber-200 bg-amber-50 p-5 shadow-sm">
      <p class="text-sm font-semibold text-amber-950">Human-owned ticket</p>
      <p class="mt-2 text-sm text-amber-900">New customer replies now stay with support and will not re-enter the automation pipeline.</p>
    </section>
  <% end %>

  <section class="grid gap-6 md:grid-cols-2">
    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Metadata</h2>
      <dl class="mt-4 space-y-2 text-sm text-slate-700">
        <div><dt class="font-medium">Company</dt><dd><%= @ticket.company.name %></dd></div>
        <div><dt class="font-medium">Customer</dt><dd><%= @ticket.customer.email %></dd></div>
        <div><dt class="font-medium">Category</dt><dd><%= @ticket.category.presence || "other" %></dd></div>
        <div><dt class="font-medium">Priority</dt><dd><%= @ticket.priority.presence || "normal" %></dd></div>
        <div><dt class="font-medium">Status</dt><dd><%= ticket_status_label(@ticket) %></dd></div>
        <div><dt class="font-medium">Current layer</dt><dd><%= @ticket.current_layer %></dd></div>
        <div><dt class="font-medium">Ownership</dt><dd><%= @ticket.manual_takeover? ? "Human-owned" : "Automation can continue" %></dd></div>
        <div><dt class="font-medium">Confidence</dt><dd><%= format_confidence(@ticket.last_confidence) %></dd></div>
        <div>
          <dt class="font-medium">Tags</dt>
          <dd class="mt-2 flex flex-wrap gap-2">
            <% if @ticket.tag_list.any? %>
              <% @ticket.tag_list.sort.each do |tag| %>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700"><%= tag %></span>
              <% end %>
            <% else %>
              <span class="text-slate-500">No tags recorded.</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>

    <div class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-slate-900">Operational Summary</h2>
      <div class="mt-4 space-y-4 text-sm text-slate-700">
        <div>
          <p class="font-medium text-slate-900">Summary</p>
          <p class="mt-1"><%= @ticket.summary.presence || "No summary recorded yet." %></p>
        </div>
        <div>
          <p class="font-medium text-slate-900">Escalation reason</p>
          <p class="mt-1"><%= @ticket.escalation_reason.presence || "No escalation reason recorded." %></p>
        </div>
        <div>
          <p class="font-medium text-slate-900">Handoff note</p>
          <p class="mt-1"><%= @ticket.handoff_note.presence || "No handoff note recorded." %></p>
        </div>
      </div>
    </div>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <div class="flex items-center justify-between gap-4">
      <h2 class="text-lg font-semibold text-slate-900">Trace Summary</h2>
      <%= link_to "Open full trace", ticket_trace_path(@ticket), class: "text-sm font-semibold text-slate-600 transition hover:text-slate-900" %>
    </div>
      <% if @ticket.agent_runs.any? %>
        <div class="mt-4 space-y-3">
          <% @ticket.agent_runs.order(:created_at).each do |run| %>
            <% snapshot = JSON.parse(run.output_snapshot || "{}") rescue {} %>
            <div class="rounded-2xl border border-slate-200 px-4 py-3">
              <div class="flex items-center justify-between gap-4">
                <p class="font-semibold text-slate-900"><%= run.agent_name %></p>
                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
                  <%= agent_source_label(snapshot) %>
                </span>
              </div>
              <p class="mt-2 text-sm text-slate-600"><%= run.reasoning_summary %></p>
              <div class="mt-3 flex flex-wrap gap-2 text-xs text-slate-600">
                <span class="rounded-full bg-slate-50 px-3 py-1">status: <%= run.status %></span>
                <span class="rounded-full bg-slate-50 px-3 py-1">decision: <%= run.decision.presence || "n/a" %></span>
                <span class="rounded-full bg-slate-50 px-3 py-1">confidence: <%= format_confidence(run.confidence) %></span>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="mt-4 text-sm text-slate-600">Agent runs and tool calls will appear here once the AI pipeline is wired in.</p>
      <% end %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Tool Calls</h2>
    <% if @ticket.tool_calls.any? %>
      <div class="mt-4 space-y-3">
        <% @ticket.tool_calls.order(:created_at).each do |call| %>
          <div class="rounded-2xl border border-slate-200 px-4 py-3">
            <div class="flex items-center justify-between gap-4">
              <p class="font-semibold text-slate-900"><%= call.tool_name %></p>
              <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700"><%= call.status %></span>
            </div>
            <p class="mt-2 text-sm text-slate-600">
              Linked run:
              <%= call.agent_run&.agent_name || "none" %>
            </p>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="mt-4 text-sm text-slate-600">No tool calls yet.</p>
    <% end %>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Conversation</h2>
    <div class="mt-4 space-y-3">
      <% @ticket.messages.order(:created_at).each do |message| %>
        <%= render "widget/tickets/message", message: message %>
      <% end %>
    </div>
  </section>

  <section id="support-reply" class="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
    <h2 class="text-lg font-semibold text-slate-900">Reply as support</h2>
    <%= form_with url: reply_ticket_path(@ticket), scope: :message, class: "mt-4 space-y-3" do |form| %>
      <%= form.text_area :content, rows: 4, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3", data: { controller: "enter-submit", action: "keydown->enter-submit#submitOnEnter" } %>
      <%= form.submit "Send reply", class: "rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white" %>
    <% end %>
  </section>
</div>
