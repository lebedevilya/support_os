<div class="mx-auto w-full max-w-6xl space-y-6">
  <div>
    <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Internal Inbox</p>
    <h1 class="text-3xl font-bold tracking-tight text-slate-900">Support tickets</h1>
  </div>

  <section class="grid gap-4 md:grid-cols-4">
    <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
      <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">Total tickets</p>
      <p class="mt-3 text-3xl font-black text-slate-900"><%= @total_tickets_count %></p>
    </article>
    <article class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm md:col-span-3">
      <div class="grid gap-4 md:grid-cols-3">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">By company</p>
          <div class="mt-3 space-y-2 text-sm text-slate-700">
            <% @companies.each do |company| %>
              <div class="flex items-center justify-between gap-4">
                <%= link_to company.name, tickets_path(request.query_parameters.merge(company_id: company.id, page: nil)), class: "hover:underline" %>
                <span><%= @company_counts[company.id] || 0 %></span>
              </div>
            <% end %>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">By status</p>
          <div class="mt-3 space-y-2 text-sm text-slate-700">
            <% @statuses.each do |status| %>
              <div class="flex items-center justify-between gap-4">
                <%= link_to status, tickets_path(request.query_parameters.merge(status: status, page: nil)), class: "hover:underline" %>
                <span><%= @status_counts[status] || 0 %></span>
              </div>
            <% end %>
          </div>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.2em] text-slate-500">By tag</p>
          <div class="mt-3 space-y-2 text-sm text-slate-700">
            <% @tags.each do |tag| %>
              <div class="flex items-center justify-between gap-4">
                <%= link_to tag.name, tickets_path(request.query_parameters.merge(tag: tag.name, page: nil)), class: "hover:underline" %>
                <span><%= @tag_counts[tag.name]&.count.to_i %></span>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </article>
  </section>

  <section class="rounded-3xl border border-slate-200 bg-white p-5 shadow-sm">
    <%= form_with url: tickets_path, method: :get, class: "grid gap-4 md:grid-cols-[1fr_1fr_1fr_auto]" do |form| %>
      <div>
        <%= form.label :company_id, "Company", class: "mb-2 block text-sm font-medium text-slate-800" %>
        <%= form.select :company_id, options_from_collection_for_select(@companies, :id, :name, params[:company_id]), { include_blank: "All companies" }, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3" %>
      </div>
      <div>
        <%= form.label :status, "Status", class: "mb-2 block text-sm font-medium text-slate-800" %>
        <%= form.select :status, options_for_select(@statuses, params[:status]), { include_blank: "All statuses" }, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3" %>
      </div>
      <div>
        <%= form.label :tag, "Tag", class: "mb-2 block text-sm font-medium text-slate-800" %>
        <%= form.select :tag, options_for_select(@tags.map(&:name), params[:tag]), { include_blank: "All tags" }, class: "block w-full rounded-2xl border border-slate-300 px-4 py-3" %>
      </div>
      <div class="flex items-end gap-3">
        <%= form.submit "Filter", class: "rounded-full bg-slate-900 px-4 py-3 text-sm font-semibold text-white" %>
        <%= link_to "Reset", tickets_path, class: "rounded-full border border-slate-300 px-4 py-3 text-sm font-semibold text-slate-900" %>
      </div>
    <% end %>
  </section>

  <div class="overflow-hidden rounded-3xl border border-slate-200 bg-white shadow-sm">
    <table class="min-w-full divide-y divide-slate-200 text-left text-sm">
      <thead class="bg-slate-50">
        <tr>
          <th class="px-4 py-3 font-semibold text-slate-700">Ticket</th>
          <th class="px-4 py-3 font-semibold text-slate-700">Company</th>
          <th class="px-4 py-3 font-semibold text-slate-700">Customer</th>
          <th class="px-4 py-3 font-semibold text-slate-700">Category</th>
          <th class="px-4 py-3 font-semibold text-slate-700">Status</th>
          <th class="px-4 py-3 font-semibold text-slate-700">Layer</th>
          <th class="px-4 py-3 font-semibold text-slate-700">Confidence</th>
          <th class="px-4 py-3 font-semibold text-slate-700">Updated</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @tickets.each do |ticket| %>
          <% escalated = ticket.status == "escalated" %>
          <tr
            class="<%= escalated ? 'bg-rose-50 hover:bg-rose-100' : 'hover:bg-slate-50' %> cursor-pointer transition"
            onclick="window.location='<%= ticket_path(ticket) %>'"
          >
            <td class="px-4 py-3"><%= link_to "##{ticket.id}", ticket_path(ticket), class: "font-semibold text-slate-900 underline-offset-2 hover:underline", onclick: "event.stopPropagation();" %></td>
            <td class="px-4 py-3"><%= ticket.company.name %></td>
            <td class="px-4 py-3"><%= ticket.customer.email %></td>
            <td class="px-4 py-3"><%= ticket.category.presence || "other" %></td>
            <td class="px-4 py-3">
              <span class="<%= escalated ? 'bg-rose-200 text-rose-900' : 'bg-slate-100 text-slate-700' %> rounded-full px-3 py-1 text-xs font-medium">
                <%= ticket.status %>
              </span>
            </td>
            <td class="px-4 py-3"><%= ticket.current_layer %></td>
            <td class="px-4 py-3"><%= format_confidence(ticket.last_confidence) %></td>
            <td class="px-4 py-3 text-slate-500"><%= ticket.updated_at.to_fs(:short) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <section class="flex items-center justify-between gap-4 text-sm text-slate-600">
    <p>Page <%= @pagy.page %> of <%= @pagy.pages %></p>
    <div><%== @pagy.series_nav if @pagy.pages > 1 %></div>
  </section>
</div>
